<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Desktop/tablet landscape: button inside nav.o_cp_switch_buttons -->
    <t t-name="andykanoz_product_kanban_desktop.ViewSwitcherDesktop" t-inherit="web.ControlPanel" t-inherit-mode="extension">
        <!-- Add capture click handler on the nav to intercept default kanban clicks
             when in Desktop Kanban mode, so user can return to native kanban. -->
        <xpath expr="//nav[hasclass('o_cp_switch_buttons')]" position="attributes">
            <attribute name="t-on-click.capture">onAkdSwitchNavClick</attribute>
        </xpath>

        <!-- Inject our Desktop Kanban button inside the nav -->
        <xpath expr="//nav[hasclass('o_cp_switch_buttons')]" position="inside">
            <button t-if="this.showDesktopKanbanButton"
                    t-att-class="'btn btn-secondary o_switch_view akd_desktop_kanban_btn' + (this.isDesktopKanbanActive ? ' active akd_desktop_kanban_active' : '')"
                    data-tooltip="Desktop Kanban"
                    t-on-click.stop="openDesktopKanban">
                <i class="fa fa-th-large"/>
            </button>
        </xpath>
    </t>

    <!-- Mobile: inject "Kanban Mobile" item inside the view switcher Dropdown -->
    <t t-name="andykanoz_product_kanban_desktop.ViewSwitcherMobile" t-inherit="web.ControlPanel" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_cp_switch_buttons')]/Dropdown/t[@t-set-slot='content']/t[@t-foreach='env.config.viewSwitcherEntries']" position="before">
            <DropdownItem t-if="this.showDesktopKanbanButton"
                          onSelected="() => this.openDesktopKanban()"
                          class="this.isDesktopKanbanActive ? 'selected' : ''">
                <i class="oi-fw fa fa-th-large"/>
                <span class="ms-1">Kanban Mobile</span>
            </DropdownItem>
        </xpath>
    </t>
</templates>
