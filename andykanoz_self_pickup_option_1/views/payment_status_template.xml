<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- PAYMENT STATUS: Button "View My Orders"                       -->
    <!-- Halaman /payment/status — setelah info Amount + Reference     -->
    <!-- ============================================================ -->
    <template id="payment_status_view_orders_button"
              name="Payment Status View Orders Button"
              inherit_id="payment.payment_status">

        <xpath expr="//div[@name='o_payment_status']" position="inside">
            <div class="text-center mt-3 mb-2">
                <a href="/my/orders" class="btn btn-primary">
                    <i class="fa fa-list-alt me-2"/>View My Orders
                </a>
            </div>
        </xpath>
    </template>

</odoo>
