<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tambah field is_self_pickup di form Delivery Carrier -->
    <record id="view_delivery_carrier_form_self_pickup" model="ir.ui.view">
        <field name="name">delivery.carrier.form.self.pickup</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='delivery_type']" position="after">
                <field name="is_self_pickup"/>
            </xpath>
        </field>
    </record>
</odoo>
