<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- DOKU Redirect Form Template                    -->
    <!--                                                -->
    <!-- Menggunakan standar Odoo 18 (Full Redirect).   -->
    <!-- Odoo akan otomatis melakukan auto-submit form  -->
    <!-- ini menuju URL pembayaran DOKU.                -->
    <!-- ============================================== -->
    <template id="redirect_form" name="DOKU Redirect Form">
        <form t-att-action="doku_payment_url" method="get"/>
    </template>

    <!-- ============================================== -->
    <!-- STRATEGY 2: Tokopedia-style Pending Page       -->
    <!-- ============================================== -->
    <template id="pending_payment_page" name="DOKU Pending Payment">
        <t t-call="portal.frontend_layout">
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 rounded-lg">
                            <div class="card-body p-4 text-center">
                                <h3 class="mb-4 fw-bold">Menunggu Pembayaran</h3>
                                
                                <div class="alert alert-warning mb-4" role="alert">
                                    <i class="fa fa-clock-o me-2"></i> Segera selesaikan pembayaran Anda sebelum waktu habis.
                                </div>
                                
                                <div class="mb-4">
                                    <p class="text-muted mb-1">Total Tagihan</p>
                                    <h2 class="text-primary fw-bold"><t t-out="amount_formatted"/></h2>
                                </div>

                                <div class="d-grid gap-3">
                                    <a t-att-href="tx.doku_payment_url" target="_blank" class="btn btn-primary btn-lg fw-bold rounded-pill">
                                        <i class="fa fa-external-link me-2"></i> Lihat Nomor Rekening / QRIS
                                    </a>
                                    
                                    <form t-attf-action="/payment/doku/cancel/{{ tx.id }}" method="post">
                                        <!-- Odoo 18 requires csrf_token for post requests in frontend -->
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-outline-danger btn-block rounded-pill w-100" onclick="return confirm('Apakah Anda yakin ingin membatalkan pembayaran ini?');">
                                            Batalkan Pembayaran
                                        </button>
                                    </form>
                                    
                                    <t t-if="tx.sale_order_ids">
                                        <a t-att-href="tx.sale_order_ids[0].get_portal_url()" class="btn btn-link text-muted mt-2">
                                            Kembali ke Rincian Pesanan
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================== -->
    <!-- STRATEGY 2: Override Sale Portal Pay Now       -->
    <!-- ============================================== -->
    <template id="sale_order_portal_template_inherit_doku" inherit_id="sale.sale_order_portal_template">
        <!-- 1. Inject button on sidebar -->
        <xpath expr="//div[@id='sale_order_sidebar_button']//a[@id='o_sale_portal_paynow']" position="before">
            <t t-set="doku_tx" t-value="sale_order.transaction_ids.filtered(lambda t: t.state == 'pending' and t.provider_code == 'doku')[:1]"/>
            <a t-if="doku_tx" 
               role="button" 
               class="btn btn-warning w-100 mb-2" 
               t-attf-href="/payment/doku/pending/{{ doku_tx.id }}">
                <i class="fa fa-clock-o"/> Lanjutkan Pembayaran
            </a>
        </xpath>
        
        <!-- Hide default sidebar Pay Now -->
        <xpath expr="//div[@id='sale_order_sidebar_button']//a[@id='o_sale_portal_paynow']" position="attributes">
            <attribute name="t-elif">sale_order._has_to_be_paid() and not doku_tx</attribute>
        </xpath>

        <!-- 2. Inject button on bottom actions -->
        <xpath expr="//div[@name='sale_order_actions']//div[@t-elif='sale_order._has_to_be_paid()']" position="before">
            <div t-if="doku_tx" class="col-sm-auto mt8">
                <a role="button" class="btn btn-warning" t-attf-href="/payment/doku/pending/{{ doku_tx.id }}">
                    <i class="fa fa-clock-o"/> Lanjutkan Pembayaran (DOKU)
                </a>
            </div>
        </xpath>

        <!-- Hide default bottom actions Pay Now -->
        <xpath expr="//div[@name='sale_order_actions']//div[@t-elif='sale_order._has_to_be_paid()']" position="attributes">
            <attribute name="t-elif">sale_order._has_to_be_paid() and not doku_tx</attribute>
        </xpath>
    </template>

</odoo>
