<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- DOKU Transaction List View (Filtered)         -->
    <!-- ============================================== -->
    <record id="view_doku_transaction_list" model="ir.ui.view">
        <field name="name">payment.transaction.doku.list</field>
        <field name="model">payment.transaction</field>
        <field name="arch" type="xml">
            <list string="DOKU Transactions" create="false" edit="false">
                <field name="create_date" string="Date"/>
                <field name="reference"/>
                <field name="doku_invoice_number" string="DOKU Invoice"/>
                <field name="partner_id"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id"/>
                <field name="doku_payment_method" string="Method"/>
                <field name="doku_acquirer" string="Bank/Wallet"/>
                <field name="doku_paid_at" string="Paid At"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'authorized'"
                       decoration-danger="state == 'error' or state == 'cancel'"/>
                <field name="doku_webhook_count" string="Webhooks" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- DOKU Transaction Search View                  -->
    <!-- ============================================== -->
    <record id="view_doku_transaction_search" model="ir.ui.view">
        <field name="name">payment.transaction.doku.search</field>
        <field name="model">payment.transaction</field>
        <field name="arch" type="xml">
            <search string="DOKU Transactions">
                <field name="reference"/>
                <field name="doku_invoice_number"/>
                <field name="partner_id"/>
                <field name="doku_payment_channel"/>

                <filter name="filter_state_done" string="Successful"
                        domain="[('state', '=', 'done')]"/>
                <filter name="filter_state_pending" string="Pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_state_error" string="Error"
                        domain="[('state', 'in', ['error', 'cancel'])]"/>

                <separator/>

                <filter name="filter_method_qris" string="QRIS"
                        domain="[('doku_payment_method', '=', 'qris')]"/>
                <filter name="filter_method_va" string="Virtual Account"
                        domain="[('doku_payment_method', '=', 'virtual_account')]"/>
                <filter name="filter_method_ewallet" string="E-Wallet"
                        domain="[('doku_payment_method', '=', 'ewallet')]"/>

                <separator/>

                <filter name="filter_today" string="Today"
                        domain="[('create_date', '&gt;=', context_today())]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('create_date', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('create_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>

                <separator/>

                <filter name="filter_no_webhook" string="No Webhook Received"
                        domain="[('doku_webhook_count', '=', 0)]"/>

                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_method" string="Payment Method"
                            context="{'group_by': 'doku_payment_method'}"/>
                    <filter name="group_acquirer" string="Bank/Wallet"
                            context="{'group_by': 'doku_acquirer'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_create_date" string="Date"
                            context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- DOKU Transaction Action                        -->
    <!-- ============================================== -->
    <record id="action_doku_transactions" model="ir.actions.act_window">
        <field name="name">DOKU Transactions</field>
        <field name="res_model">payment.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('provider_code', '=', 'doku')]</field>
        <field name="context">{'search_default_filter_today': 1}</field>
        <field name="search_view_id" ref="view_doku_transaction_search"/>
        <field name="view_ids"
               eval="[(5, 0, 0),
                      (0, 0, {'view_mode': 'list', 'view_id': ref('view_doku_transaction_list')}),
                      (0, 0, {'view_mode': 'form'})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No DOKU transactions yet
            </p>
            <p>
                DOKU payment transactions will appear here once customers
                start making payments through the DOKU payment provider.
            </p>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- DOKU Menu Items                                -->
    <!-- ============================================== -->
    <menuitem id="menu_doku_root"
              name="DOKU Payment"
              parent="account.menu_finance"
              sequence="100"
              groups="account.group_account_user"/>

    <menuitem id="menu_doku_transactions"
              name="Transactions"
              parent="menu_doku_root"
              action="action_doku_transactions"
              sequence="10"/>

    <menuitem id="menu_doku_provider_config"
              name="Configuration"
              parent="menu_doku_root"
              action="payment.action_payment_provider"
              sequence="20"
              groups="base.group_system"/>

</odoo>
