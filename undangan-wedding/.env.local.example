# Supabase configuration
# Get these from your Supabase project at https://app.supabase.com → Project Settings → API
# Replace the values below with your actual credentials, then rename this file to .env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Wedding event configuration (used at build time)
NEXT_PUBLIC_WEDDING_DATE=2026-06-14T08:00:00+08:00
NEXT_PUBLIC_SITE_URL=https://undangan.gopokaja.com
