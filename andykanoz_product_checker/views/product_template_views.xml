<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Apply barcode_camera widget to the barcode field on product.template form -->
    <record id="product_template_form_view_barcode_camera" model="ir.ui.view">
        <field name="name">product.template.form.barcode.camera</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="barcode" position="attributes">
                <attribute name="widget">barcode_camera</attribute>
            </field>
        </field>
    </record>

</odoo>
