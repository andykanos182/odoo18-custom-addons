<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_process_batch_jobs" model="ir.cron">
            <field name="name">AndykaNoz Auto Edit: Process Batch Jobs</field>
            <field name="model_id" ref="model_andykanoz_batch_edit_job"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_jobs()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="seq_batch_edit_job" model="ir.sequence">
            <field name="name">Auto Edit Batch Job</field>
            <field name="code">andykanoz.batch.edit.job</field>
            <field name="prefix">BATCH/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
