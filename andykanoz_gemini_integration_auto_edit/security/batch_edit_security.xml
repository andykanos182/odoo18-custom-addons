<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="batch_edit_job_rule_user" model="ir.rule">
            <field name="name">Batch Edit Job: own jobs only</field>
            <field name="model_id" ref="model_andykanoz_batch_edit_job"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="batch_edit_job_rule_admin" model="ir.rule">
            <field name="name">Batch Edit Job: admin sees all</field>
            <field name="model_id" ref="model_andykanoz_batch_edit_job"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <record id="batch_edit_job_line_rule_user" model="ir.rule">
            <field name="name">Batch Edit Job Line: own jobs only</field>
            <field name="model_id" ref="model_andykanoz_batch_edit_job_line"/>
            <field name="domain_force">[('job_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="batch_edit_job_line_rule_admin" model="ir.rule">
            <field name="name">Batch Edit Job Line: admin sees all</field>
            <field name="model_id" ref="model_andykanoz_batch_edit_job_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>
