<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_andykanoz_batch_edit_job_list" model="ir.ui.view">
        <field name="name">andykanoz.batch.edit.job.list</field>
        <field name="model">andykanoz.batch.edit.job</field>
        <field name="arch" type="xml">
            <list string="Batch Edit Jobs" decoration-info="state == 'running'"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'"
                  decoration-danger="state == 'failed'">
                <field name="name"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="total_count"/>
                <field name="processed_count"/>
                <field name="failed_count"/>
                <field name="created_at"/>
                <field name="completed_at"/>
            </list>
        </field>
    </record>

    <record id="view_andykanoz_batch_edit_job_form" model="ir.ui.view">
        <field name="name">andykanoz.batch.edit.job.form</field>
        <field name="model">andykanoz.batch.edit.job</field>
        <field name="arch" type="xml">
            <form string="Batch Edit Job">
                <header>
                    <button name="action_cancel" type="object" string="Cancel Job"
                            class="btn-danger"
                            invisible="state in ('done', 'cancelled', 'failed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,running,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="created_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                            <field name="current_line_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_count" readonly="1"/>
                            <field name="processed_count" readonly="1"/>
                            <field name="failed_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="1">
                                <list decoration-success="state == 'done'"
                                      decoration-danger="state == 'failed'"
                                      decoration-muted="state == 'pending'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_tmpl_id"/>
                                    <field name="state"/>
                                    <field name="processed_at"/>
                                    <field name="error_message"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_andykanoz_batch_edit_job" model="ir.actions.act_window">
        <field name="name">Batch Edit Jobs</field>
        <field name="res_model">andykanoz.batch.edit.job</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_andykanoz_batch_edit_job"
              name="Auto Edit Batch Jobs"
              parent="base.menu_administration"
              action="action_andykanoz_batch_edit_job"
              sequence="100"
              groups="base.group_system"/>

</odoo>
