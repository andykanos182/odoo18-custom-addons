<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="product_template_form_view_auto_edit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.auto.edit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='image_1920'][1]" position="after">
                <button name="action_auto_white_background" type="object" class="btn btn-link p-0 mt-n2" icon="fa-magic" string="Auto White BG" invisible="not image_1920" confirm="Remove background and apply white background using Gemini AI?"/>
                <button name="action_auto_professional_edit" type="object" class="btn btn-link p-0 mt-n2 ml-2" icon="fa-star" string="Auto Pro Edit" invisible="not image_1920" confirm="Process image with Professional preset (remove hands + refine edges)?"/>
            </xpath>
        </field>
    </record>

</odoo>
