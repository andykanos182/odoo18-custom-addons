<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_andykanoz_batch_edit_wizard_form" model="ir.ui.view">
        <field name="name">andykanoz.batch.edit.wizard.form</field>
        <field name="model">andykanoz.batch.edit.wizard</field>
        <field name="arch" type="xml">
            <form string="Auto White BG (Bulk)">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not blocking_reason">
                        <field name="blocking_reason" nolabel="1" readonly="1"/>
                    </div>

                    <group>
                        <group string="Selection">
                            <field name="total_selected" readonly="1"/>
                            <field name="total_with_image" readonly="1"/>
                            <field name="total_skipped" readonly="1"/>
                        </group>
                        <group string="Daily Quota">
                            <field name="daily_quota_limit" readonly="1"/>
                            <field name="daily_quota_used" readonly="1"/>
                            <field name="daily_quota_remaining" readonly="1"/>
                        </group>
                    </group>

                    <field name="has_active_job" invisible="1"/>
                    <field name="can_start" invisible="1"/>

                    <group string="Auto Edit Options">
                        <field name="preset"/>
                        <field name="custom_prompt" invisible="preset != 'custom'"/>
                        <field name="output_format"/>
                        <field name="refine_edges"/>
                        <field name="preserve_shadows"/>
                        <field name="max_dimension"/>
                    </group>

                    <notebook>
                        <page string="Products to Process">
                            <field name="product_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="default_code"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_start" type="object" string="Start" class="btn-primary" invisible="not can_start"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
