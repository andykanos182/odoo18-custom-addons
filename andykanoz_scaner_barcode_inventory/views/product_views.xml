<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_barcode_scanner" model="ir.ui.view">
        <field name="name">product.template.form.barcode.scanner</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="widget">andykanoz_barcode_scanner</attribute>
            </xpath>
        </field>
    </record>

</odoo>
