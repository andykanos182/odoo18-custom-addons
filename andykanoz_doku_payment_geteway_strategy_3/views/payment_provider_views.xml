<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- DOKU Payment Provider Form View Extension     -->
    <!-- ============================================== -->
    <record id="payment_provider_form_doku" model="ir.ui.view">
        <field name="name">payment.provider.form.doku</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">

            <!-- ============================================== -->
            <!-- Inject DOKU credentials INTO default          -->
            <!-- 'Credentials' tab (Odoo standard pattern)     -->
            <!-- ============================================== -->
            <xpath expr="//page[@name='credentials']" position="inside">
                <group invisible="code != 'doku'">

                    <!-- Quick info banner -->
                    <div class="alert alert-info" role="alert" colspan="2">
                        <i class="fa fa-info-circle"/>
                        Get your credentials from
                        <a href="https://sandbox.doku.com/bo/login" target="_blank">
                            <strong>DOKU Sandbox Dashboard</strong>
                        </a>
                        (testing) or
                        <a href="https://dashboard.doku.com/bo/dashboard" target="_blank">
                            <strong>DOKU Production Dashboard</strong>
                        </a>
                        (live).
                    </div>

                    <group string="DOKU API Credentials">
                        <field name="doku_environment"
                               widget="radio"
                               options="{'horizontal': true}"/>
                        <field name="doku_merchant_code"
                               placeholder="e.g., MCH-1234567890"/>
                        <field name="doku_client_id"
                               placeholder="e.g., MCH-XXXX-CLIENT"/>
                        <field name="doku_secret_key"
                               password="True"
                               placeholder="Your secret key"/>
                    </group>

                    <group string="Connection Test">
                        <button name="action_doku_test_connection"
                                string="Test Connection"
                                type="object"
                                class="btn-primary"
                                icon="fa-plug"/>
                    </group>

                </group>
            </xpath>

            <!-- ============================================== -->
            <!-- Add DOKU configuration tab (settings only)    -->
            <!-- ============================================== -->
            <xpath expr="//page[@name='credentials']" position="after">
                <page string="DOKU Configuration"
                      name="doku_configuration"
                      invisible="code != 'doku'">

                    <!-- Quick Access Links to DOKU Dashboard -->
                    <div class="alert alert-secondary" role="alert">
                        <h5 class="alert-heading">
                            <i class="fa fa-link"/> DOKU Quick Access Links
                        </h5>
                        <p class="mb-1">
                            <strong>Sandbox (Testing):</strong>
                            <a href="https://sandbox.doku.com/bo/login"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary ms-2">
                                <i class="fa fa-external-link"/> Open Sandbox Dashboard
                            </a>
                        </p>
                        <p class="mb-1">
                            <strong>Production (Live):</strong>
                            <a href="https://dashboard.doku.com/bo/dashboard"
                               target="_blank"
                               class="btn btn-sm btn-outline-success ms-2">
                                <i class="fa fa-external-link"/> Open Production Dashboard
                            </a>
                        </p>
                        <p class="mb-1">
                            <strong>Payment Simulator:</strong>
                            <a href="https://sandbox.doku.com/integration/simulator/"
                               target="_blank"
                               class="btn btn-sm btn-outline-info ms-2">
                                <i class="fa fa-flask"/> Open Simulator
                            </a>
                        </p>
                        <p class="mb-0">
                            <strong>Developer Docs:</strong>
                            <a href="https://developers.doku.com"
                               target="_blank"
                               class="btn btn-sm btn-outline-dark ms-2">
                                <i class="fa fa-book"/> Open Documentation
                            </a>
                        </p>
                    </div>

                    <!-- Payment Methods Section -->
                    <group string="Enabled Payment Methods">
                        <group>
                            <field name="doku_enable_qris"/>
                            <field name="doku_enable_va"/>
                            <field name="doku_enable_ewallet"/>
                        </group>
                    </group>

                    <!-- Payment Settings -->
                    <group string="Payment Settings">
                        <group>
                            <field name="doku_payment_expiry_minutes"/>
                        </group>
                    </group>

                    <!-- Webhook URLs Section -->
                    <group string="Webhook Configuration"
                           help="Copy these URLs to DOKU Dashboard for proper integration.">
                        <field name="doku_webhook_url" readonly="1"/>
                        <field name="doku_return_url" readonly="1"/>
                    </group>

                    <!-- Help Section -->
                    <div class="alert alert-info" role="alert"
                         invisible="doku_environment != 'sandbox'">
                        <h4 class="alert-heading">
                            <i class="fa fa-info-circle"/> Sandbox Mode
                        </h4>
                        <p>
                            You are currently in <strong>Sandbox</strong> mode.
                            All transactions are simulated and no real money is processed.
                        </p>
                        <p class="mb-0">
                            Use the <a href="https://sandbox.doku.com/integration/simulator/" target="_blank">
                            <strong>Payment Simulator</strong></a> to test payments.
                        </p>
                    </div>

                    <div class="alert alert-warning" role="alert"
                         invisible="doku_environment != 'production'">
                        <h4 class="alert-heading">
                            <i class="fa fa-exclamation-triangle"/> Production Mode
                        </h4>
                        <p>
                            You are in <strong>Production</strong> mode.
                            All transactions are <strong>REAL</strong> and will charge actual money.
                        </p>
                        <p class="mb-0">
                            Manage transactions at
                            <a href="https://dashboard.doku.com/bo/dashboard" target="_blank">
                                <strong>DOKU Production Dashboard</strong>
                            </a>.
                        </p>
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
