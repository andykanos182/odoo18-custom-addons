<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Distance Shipping Configuration di form Delivery Carrier -->
    <record id="view_delivery_carrier_form_distance" model="ir.ui.view">
        <field name="name">delivery.carrier.form.distance</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">

            <!-- Sembunyikan margin dan fixed_margin saat distance -->
            <xpath expr="//field[@name='margin']" position="attributes">
                <attribute name="invisible">delivery_type == 'distance'</attribute>
            </xpath>
            <xpath expr="//field[@name='fixed_margin']" position="attributes">
                <attribute name="invisible">delivery_type == 'distance'</attribute>
            </xpath>

            <!-- Tambah Distance Shipping Configuration setelah group utama, sebelum notebook -->
            <xpath expr="//notebook" position="before">
                <group name="distance_config"
                       string="Distance Shipping Configuration"
                       invisible="delivery_type != 'distance'">
                    <group>
                        <field name="distance_base_fee" string="Base Fee (Rp)"/>
                        <field name="distance_threshold_km" string="Threshold (km)"/>
                        <field name="distance_travel_mode" string="Route Mode"/>
                    </group>
                    <group>
                        <field name="distance_per_km_fee" string="Fee per KM (Rp)"/>
                        <field name="distance_max_km" string="Max Distance (km)"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
