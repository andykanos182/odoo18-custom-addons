<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="andykanoz_google_maps_peta.GMapWidget">
        <div class="o_gmap_widget">
            <!-- Error message -->
            <div t-if="state.errorMsg" class="alert alert-warning mb-2" style="font-size:0.85em;">
                <i class="fa fa-exclamation-triangle me-1"/>
                <t t-esc="state.errorMsg"/>
            </div>

            <!-- Map container -->
            <div t-ref="gmap_container"
                 style="width:100%; height:350px; border:1px solid #ced4da; border-radius:4px; background:#e9ecef;"/>

            <!-- Tombol Lokasi Saya -->
            <div class="mt-2">
                <button type="button"
                        class="btn btn-sm btn-outline-primary"
                        t-on-click="onClickMyLocation">
                    <i class="fa fa-crosshairs me-1"/>
                    Lokasi Saya
                </button>
            </div>
        </div>
    </t>

</templates>
