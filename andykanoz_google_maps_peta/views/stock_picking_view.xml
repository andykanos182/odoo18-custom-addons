<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. Form View: Link Navigation dari koordinat -->
    <record id="view_picking_form_gmaps_link_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.gmaps.link.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="gmaps_navigation_url"
                       widget="url"
                       string="Link Navigation"
                       placeholder="Customer location not available..."/>
            </xpath>

        </field>
    </record>

    <!-- 2. List View: Tombol navigasi -->
    <record id="view_picking_tree_gmaps_link_inherit" model="ir.ui.view">
        <field name="name">stock.picking.tree.gmaps.link.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='name']" position="before">
                <button name="action_open_gmaps"
                       type="object"
                       icon="fa-map-marker"
                       string="Navigate"
                       help="Open customer location in Google Maps"/>
            </xpath>
        </field>
    </record>

</odoo>
