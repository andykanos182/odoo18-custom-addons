<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_quick_purchase" model="ir.ui.view">
        <field name="name">purchase.order.form.quick.purchase</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_quick_purchase" 
                        string="Quick Entry" 
                        type="object" 
                        class="btn-primary" 
                        invisible="state not in ('draft', 'sent')"/>
            </xpath>
        </field>
    </record>
</odoo>