<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_only_form_view_inherit_ref_generator" model="ir.ui.view">
        <field name="name">product.template.form.inherit.ref.generator</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="replace">
                <label for="default_code"/>
                <div class="o_row" name="default_code_row">
                    <field name="default_code" invisible="product_variant_count &gt; 1"/>
                    <button name="action_generate_internal_reference" type="object" string="Generate Code" class="btn btn-secondary" icon="fa-cogs" invisible="product_variant_count &gt; 1 or default_code"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_view_inherit_ref_generator" model="ir.ui.view">
        <field name="name">product.product.form.inherit.ref.generator</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="replace">
                <label for="default_code"/>
                <div class="o_row" name="default_code_row">
                    <field name="default_code"/>
                    <button name="action_generate_internal_reference" type="object" string="Generate Code" class="btn btn-secondary" icon="fa-cogs" invisible="default_code"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
